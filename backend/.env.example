# Backend-Konfiguration (kopiere nach .env und passe an)

# Port des Backends
PORT=8080

# BRouter-Routing-Server.
# - Selbst gehostet (docker-compose): http://localhost:17777/brouter
# - Öffentliche Instanz (zum schnellen Testen):  https://bikerouter.de/brouter
BROUTER_URL=http://localhost:17777/brouter

# Overpass-Endpunkt (POIs + OSM-Baustellen)
OVERPASS_URL=https://overpass-api.de/api/interpreter

# Nominatim-Endpunkt (Geocoding / Adresssuche)
NOMINATIM_URL=https://nominatim.openstreetmap.org

# Autobahn GmbH API (Echtzeit-Autobahn-Baustellen)
AUTOBAHN_URL=https://verkehr.autobahn.de/o/autobahn

# Kontakt für User-Agent (Fair-Use bei OSM-Diensten)
CONTACT_EMAIL=you@example.com
